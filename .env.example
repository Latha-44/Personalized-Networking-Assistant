# Copy this file to .env and fill in values as needed.

# SQLite by default (no setup required). To use PostgreSQL instead:
# DATABASE_URL=postgresql://user:password@localhost:5432/networking_assistant
DATABASE_URL=sqlite:///./data/networking_assistant.db

# Base URL the Streamlit frontend uses to reach the FastAPI backend
API_BASE_URL=http://localhost:8000

# Optional: only needed if you extend the project to call Gemini directly
# GOOGLE_GEMINI_API_KEY=your_key_here
